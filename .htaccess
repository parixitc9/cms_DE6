RewriteEngine On

# If the file or folder actually exists (like images/CSS), serve it normally
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Intercept any .html link and send it to index.php
RewriteRule ^(.*)\.html$ index.php?page=$1 [QSA,L]

# Default the root directory to the home page
RewriteRule ^$ index.php?page=home [QSA,L]